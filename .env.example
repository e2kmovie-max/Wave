# ───────────────────────────────────────────────────────────
# Wave — environment variables (Stage 4)
# Copy this file to .env at the repo root and fill in values.
# ───────────────────────────────────────────────────────────

# MongoDB (used by web + bot via shared package)
MONGODB_URI=mongodb://wave:wave@localhost:27017/wave?authSource=admin

# Symmetric secret for signing cookies/sessions and per-instance HMAC.
# Generate with: openssl rand -base64 48
APP_SECRET=replace-me-with-a-long-random-string

# Public URL of the web app (used for OAuth redirects, Telegram WebApp, etc.)
PUBLIC_WEB_URL=http://localhost:3000

# ── Google OAuth (Stage 1: stub-friendly — leave empty to disable) ──
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${PUBLIC_WEB_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram bot (Stage 1: stub-friendly — leave empty to disable) ──
# Create the bot via @BotFather, copy the token here, and set the username
# (without @) for invite deep-links and Mini App linking.
BOT_TOKEN=
BOT_USERNAME=

# Comma-separated Telegram user IDs that should have admin privileges.
# These users get the /admin command in the bot and the /admin pages on
# the web app (after they sign in once so we know their Wave user id).
ADMIN_TELEGRAM_IDS=

# Comma-separated Google emails that should have admin privileges on the
# web admin (/admin pages). On first /admin visit the user's Wave doc gets
# isAdmin=true sticky-set, so this list only needs to include the seed admins.
ADMIN_GOOGLE_EMAILS=

# Web app port (custom Next.js server with room WebSocket upgrades)
WEB_PORT=3000

# ── Streaming instances (Stage 3) ───────────────────────────
# JSON array of streaming instances upserted into Mongo on master startup.
# Each entry: { name, url, secret, isLocal?, enabled?, maxStreams? }.
# Records added through the (future) admin panel are NEVER overwritten by
# this sync. Removing an entry from this list does not remove it from Mongo.
#
# Example (one local instance):
#   INSTANCES_JSON=[{"name":"local","url":"http://localhost:8080","secret":"replace-me","isLocal":true}]
INSTANCES_JSON=

# Convenience: secret consumed by docker-compose's `instance` profile.
# Match this with the corresponding entry in INSTANCES_JSON above.
INSTANCE_LOCAL_SECRET=dev-instance-secret-change-me

# How often the master probes each instance's /health (seconds).
INSTANCE_HEALTH_INTERVAL_SECONDS=15
# Timeout for each /health probe (milliseconds).
INSTANCE_HEALTH_TIMEOUT_MS=5000
